<Window x:Class="JdkManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:JdkManager.ViewModels"
        xmlns:converters="clr-namespace:JdkManager.Converters"
        mc:Ignorable="d"
        Title="JDK Manager - Java 版本切换工具"
        Height="600" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="#F1F5F9"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=False}">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>

        <!-- 当前激活指示器 -->
        <Style x:Key="ActiveIndicator" TargetType="Ellipse">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="Fill" Value="#16A34A"/>
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题和当前版本 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="🎯 JDK Manager" FontSize="24" FontWeight="Bold" Foreground="#1E293B"/>
            <TextBlock Text="一键切换 Java 版本" FontSize="12" Foreground="#64748B" Margin="0,4,0,0"/>

            <!-- 当前版本信息 -->
            <Border Background="White" CornerRadius="8" Padding="12" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="当前激活的 Java 版本" Foreground="#64748B" FontSize="12"/>
                    <TextBlock Text="{Binding CurrentVersion}" Foreground="#1E293B" FontSize="14" FontWeight="Medium" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- 管理员权限提示 -->
            <Border Background="#FEF3C7" CornerRadius="6" Padding="8" Margin="0,8,0,0" Visibility="{Binding IsAdministrator, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Visible}">
                <TextBlock Text="⚠ 需要管理员权限才能切换 JDK" Foreground="#D97706" FontSize="12"/>
            </Border>
        </StackPanel>

        <!-- JDK 列表 -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="已安装的 JDK" FontSize="16" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,12"/>

            <Grid Grid.Row="1">
                <ListBox
                    ItemsSource="{Binding Jdks}"
                    SelectedItem="{Binding SelectedJdk}"
                    ItemContainerStyle="{StaticResource JdkListItem}"
                    BorderThickness="0"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 激活指示器 -->
                                <Ellipse Style="{StaticResource ActiveIndicator}" VerticalAlignment="Center" Margin="0,0,10,0"/>

                                <!-- JDK 信息 -->
                                <StackPanel Grid.Column="1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="Medium" Foreground="#1E293B"/>
                                        <TextBlock Text=" • " Foreground="#94A3B8" Margin="4,0"/>
                                        <TextBlock Text="{Binding Vendor}" FontSize="12" Foreground="#64748B"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Path}" FontSize="11" Foreground="#94A3B8" TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- 加载提示覆盖层 -->
                <Border Background="#F8FAFC" CornerRadius="8" Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}}" Opacity="0.9">
                    <TextBlock Text="{Binding StatusMessage}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#64748B"/>
                </Border>
            </Grid>
        </Grid>

        <!-- 工具按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,16,0,0">
            <Button Content="⟳ 刷新" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
            <Button Content="+ 添加" Command="{Binding AddJdkCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
            <Button Content="- 删除" Command="{Binding DeleteJdkCommand}" Style="{StaticResource SecondaryButton}"/>
            <Button Content="📂 打开目录" Command="{Binding OpenInExplorerCommand}" Style="{StaticResource SecondaryButton}" Margin="16,0,0,0" HorizontalAlignment="Right"/>
        </StackPanel>

        <!-- 切换按钮 -->
        <Button Grid.Row="3"
                Content="切换选中版本"
                Command="{Binding SwitchCommand}"
                Style="{StaticResource PrimaryButton}"
                Padding="24,12"
                FontSize="15"
                Margin="0,20,0,0"
                Height="50"/>

        <!-- 状态栏 -->
        <Border Grid.Row="4" Background="White" CornerRadius="6" Padding="12" Margin="0,16,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#64748B" FontSize="13" TextTrimming="CharacterEllipsis"/>
        </Border>
    </Grid>
</Window>
